{
  "name": "easywork",
  "version": "0.4.4",
  "private": true,
  "license": "MIT",
  "description": "本地 AI 工作台 — 下载并运行本地模型，Agent 工具(Skills/MCP)，IM + 记忆",
  "type": "module",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "esbuild": "0.27.2"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:daemon": "npm run dev --workspace @ew/daemon",
    "dev:ui": "npm run dev --workspace @ew/ui",
    "dev:desktop": "npm run dev --workspace @ew/desktop",
    "test": "vitest run",
    "e2e:prepare": "npm run build -- --filter=@ew/daemon",
    "e2e:install": "playwright install chromium",
    "test:e2e": "npm run e2e:prepare && playwright test",
    "test:e2e:headed": "npm run e2e:prepare && playwright test --headed",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "test:coverage": "vitest run --coverage",
    "release:check-version": "node scripts/check-release-version.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "react": "^19.2.7",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.0.0"
  }
}
