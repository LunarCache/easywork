{
  "name": "@ew/daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "easywork": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"node dist/cli.js serve\"",
    "start": "node dist/cli.js serve",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@ew/core": "*",
    "@ew/shared": "*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.0"
  }
}
