{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyWork",
  "version": "0.4.6",
  "identifier": "ai.easywork.app",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --workspace @ew/ui",
    "beforeBuildCommand": "npm run build --workspace @ew/ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EasyWork — 本地 AI 工作台",
        "width": 1200,
        "height": 800,
        "minWidth": 880,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 19, "y": 23 }
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'"],
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "http://127.0.0.1:*",
          "http://localhost:*",
          "ws://127.0.0.1:*",
          "ws://localhost:*",
          "https:",
          "wss:"
        ],
        "img-src": ["'self'", "asset:", "http://asset.localhost", "data:", "blob:", "https:"],
        "media-src": ["'self'", "data:", "blob:"],
        "frame-src": ["'self'", "data:", "blob:", "http:", "https:"],
        "script-src": ["'self'", "'unsafe-inline'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "font-src": ["'self'", "data:"],
        "object-src": ["'none'"],
        "base-uri": ["'self'"],
        "form-action": ["'none'"],
        "frame-ancestors": ["'none'"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "resources": {
      "../../daemon/dist-sea": "daemon"
    }
  }
}
