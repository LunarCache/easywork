{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyWork",
  "version": "0.2.0",
  "identifier": "ai.easywork.app",
  "build": {
    "frontendDist": "../../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev --workspace @ew/ui",
    "beforeBuildCommand": "npm run build --workspace @ew/ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EasyWork — 本地 AI 工作台",
        "width": 1200,
        "height": 800,
        "minWidth": 880,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "resources": {
      "../../daemon/dist-sea": "daemon"
    }
  }
}
